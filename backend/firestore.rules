rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /activities/{activityId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'zwymAmTWr0VQaU6wkeWvUJO7CzU2';
    }
    match /bookings/{bookingId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.uid == 'zwymAmTWr0VQaU6wkeWvUJO7CzU2';
    }
  }
}
